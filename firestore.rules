rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.studentId;
    }

    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isDefaultAdmin() {
      return isAuthenticated() && request.auth.token.email == "muazdari00@gmail.com" && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isDefaultAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'role']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['teacher', 'student'];
    }

    function isValidTest(data) {
      return data.keys().hasAll(['id', 'title', 'questions', 'createdAt', 'timerMinutes', 'creatorId']) &&
             data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.questions is list && data.questions.size() <= 60 &&
             data.timerMinutes is number && data.timerMinutes > 0 &&
             data.creatorId is string;
    }

    function isValidResult(data) {
      return data.keys().hasAll(['id', 'testId', 'studentId', 'score', 'timestamp']) &&
             data.id is string &&
             data.testId is string &&
             data.studentId is string &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.timestamp is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
    }

    match /tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isTeacher() || isAdmin()) && isValidTest(request.resource.data);
      allow update: if isAuthenticated() && (isTeacher() || isAdmin()) && isValidTest(request.resource.data);
      allow delete: if isAuthenticated() && (isTeacher() || isAdmin());
    }

    match /results/{resultId} {
      allow read: if isAuthenticated() && (isDocOwner() || isTeacher() || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid && isValidResult(request.resource.data);
      allow update: if isAuthenticated() && (
        (isDocOwner() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['feedbackRead'])) ||
        ((isTeacher() || isAdmin()) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teacherFeedback', 'feedbackRead']))
      );
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
